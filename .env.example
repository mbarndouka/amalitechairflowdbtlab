AIRFLOW_UID=1000
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.1
AIRFLOW_PROJ_DIR=.

POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=airflow

MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_DATABASE=airflow
MYSQL_USER=airflow
MYSQL_PASSWORD=change-me-mysql-password

AIRFLOW__CORE__FERNET_KEY=change-me-generate-with-python-cryptography-fernet
AIRFLOW__API_AUTH__JWT_SECRET=change-me-long-random-jwt-secret
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=change-me-airflow-admin-password
_PIP_ADDITIONAL_REQUIREMENTS=
